<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Shares habit data with the widget extension through the app group container. -->
  <key>com.apple.security.application-groups</key>
  <array>
    <string>group.com.breakingthebot.HabitTracker</string>
  </array>
</dict>
</plist>
